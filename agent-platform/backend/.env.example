# Agent Platform Backend Configuration
# Copy to .env and fill in values for your environment

# ============================================
# ENVIRONMENT & BASE
# ============================================
ENVIRONMENT=local
DEBUG=true

# ============================================
# APPLICATION IDENTITY
# ============================================
APP_NAME=agent-platform
APP_VERSION=0.1.0
SECRET_KEY=your-secret-key-must-be-at-least-32-characters-long-please-change-this-value

# ============================================
# DATABASE (STEP-10)
# ============================================
DATABASE_URL=postgresql://localhost:5432/agent_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30

# ============================================
# REDIS (STEP-11.2)
# ============================================
REDIS_URL=redis://localhost:6379/0
REDIS_SENTINEL_ENABLED=false

# ============================================
# GITHUB OAUTH (STEP-2)
# ============================================
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=http://localhost:5173/callback

# ============================================
# SESSION (STEP-3, STEP-5.1)
# ============================================
SESSION_TIMEOUT_SECONDS=3600
SESSION_REFRESH_THRESHOLD_SECONDS=300

# ============================================
# SECURITY & TOKENS (STEP-11.2, STEP-11.3)
# ============================================
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=["http://localhost:5173"]

# ============================================
# SECRETS MANAGER (STEP-11.2)
# ============================================
SECRETS_MANAGER=env

# ============================================
# LOGGING (STEP-11.2)
# ============================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============================================
# OBSERVABILITY (STEP-11.2)
# ============================================
OTEL_ENABLED=false

# ============================================
# AUDIT & RBAC (STEP-11.3)
# ============================================
AUDIT_ENABLED=true
RBAC_ENABLED=true
